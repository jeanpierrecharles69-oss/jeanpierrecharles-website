{
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "config/**"
    },
    "api/diagnostic-deliver.ts": {
      "maxDuration": 15
    }
  },
  "regions": ["cdg1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/insights/:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(LinkedInBot|facebookexternalhit|Twitterbot|Googlebot|bingbot|Slackbot|WhatsApp|Discordbot|TelegramBot).*"
        }
      ],
      "destination": "/api/og-render?slug=:slug*"
    },
    {
      "source": "/insights/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/merci",
      "destination": "/index.html"
    },
    {
      "source": "/en",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
