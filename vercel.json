{
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "config/**"
    },
    "api/generate-diagnostic.ts": {
      "memory": 1024,
      "maxDuration": 300,
      "includeFiles": "config/**"
    },
    "api/generate-veille-report.ts": {
      "memory": 1024,
      "maxDuration": 300,
      "includeFiles": "config/**"
    },
    "api/distribute-veille-report.ts": {
      "memory": 512,
      "maxDuration": 300,
      "includeFiles": "config/**"
    }
  },
  "regions": ["cdg1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/insights/:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(LinkedInBot|facebookexternalhit|Twitterbot|Googlebot|bingbot|Slackbot|WhatsApp|Discordbot|TelegramBot).*"
        }
      ],
      "destination": "/api/og-render?slug=:slug*"
    },
    {
      "source": "/insights/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/merci",
      "destination": "/index.html"
    },
    {
      "source": "/en",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com; connect-src 'self' https://api.mollie.com https://generativelanguage.googleapis.com https://api.anthropic.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; frame-src https://www.mollie.com https://*.mollie.com; object-src 'none'; base-uri 'self'" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=(self https://*.mollie.com)" }
      ]
    }
  ]
}
